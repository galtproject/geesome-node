#!/usr/bin/env bash
set -euo pipefail

usage() {
	cat <<'USAGE'
Usage:
  CONFIRM_RESTORED_BACKUP=1 DATABASE_NAME=<restored-db> bash/database-migration-rehearsal

Runs the production migration chain against a restored Postgres backup, syncs
model-created tables, reconciles canonical storage objects, and then runs the
migration integrity audit.

Safety:
  - Refuses to run unless CONFIRM_RESTORED_BACKUP=1.
  - Refuses to use the implicit default DATABASE_NAME.
  - Refuses DATABASE_NAME=geesome_node unless ALLOW_DEFAULT_DATABASE=1.

Expected target:
  A disposable database restored from backup, not a live user-facing database.
USAGE
}

if [[ "${1:-}" == "-h" || "${1:-}" == "--help" ]]; then
	usage
	exit 0
fi

if [[ "${CONFIRM_RESTORED_BACKUP:-}" != "1" ]]; then
	echo "Refusing to run: set CONFIRM_RESTORED_BACKUP=1 after restoring a disposable backup target." >&2
	usage >&2
	exit 2
fi

if [[ -z "${DATABASE_NAME:-}" ]]; then
	echo "Refusing to run: set DATABASE_NAME to the restored backup database name." >&2
	exit 2
fi

if [[ "${DATABASE_NAME}" == "geesome_node" && "${ALLOW_DEFAULT_DATABASE:-}" != "1" ]]; then
	echo "Refusing to run against DATABASE_NAME=geesome_node without ALLOW_DEFAULT_DATABASE=1." >&2
	echo "Use a disposable restored database name for rehearsal whenever possible." >&2
	exit 2
fi

echo "Migration rehearsal target:"
echo "  DATABASE_HOST=${DATABASE_HOST:-localhost}"
echo "  DATABASE_PORT=${DATABASE_PORT:-5432}"
echo "  DATABASE_USER=${DATABASE_USER:-geesome}"
echo "  DATABASE_NAME=${DATABASE_NAME}"
echo

npm run migrate-all-database
npm run database:sync-models
CONFIRM_STORAGE_OBJECT_REPAIR=1 npm run database:storage-objects-integrity -- --repair
npm run database:migration-integrity
